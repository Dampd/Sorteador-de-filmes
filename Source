<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CineSorteio 🎬</title>
    <style>
        :root { --pop: #e50914; --bg: #141414; --card: #1f1f1f; --text: #ffffff; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: var(--bg); color: var(--text); display: flex; flex-direction: column; align-items: center; padding: 20px; }
        .container { background: var(--card); padding: 30px; border-radius: 15px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); width: 100%; max-width: 500px; text-align: center; }
        h1 { margin-bottom: 20px; color: var(--pop); }
        textarea { width: 100%; height: 150px; background: #333; color: white; border: 1px solid #444; border-radius: 8px; padding: 10px; box-sizing: border-box; resize: none; margin-bottom: 15px; }
        button { width: 100%; padding: 15px; border: none; border-radius: 8px; font-weight: bold; cursor: pointer; font-size: 16px; transition: 0.3s; margin-bottom: 10px; }
        .btn-sortear { background: var(--pop); color: white; }
        .btn-sortear:hover { background: #b20710; transform: scale(1.02); }
        .btn-limpar { background: #444; color: #ccc; font-size: 12px; }
        #resultado { margin-top: 25px; min-height: 50px; font-size: 22px; font-weight: bold; color: #f1c40f; display: flex; align-items: center; justify-content: center; }
        .highlight { animation: pop-in 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
        @keyframes pop-in { 0% { transform: scale(0.5); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }
    </style>
</head>
<body>

    <div class="container">
        <h1>CineSorteio</h1>
        <p>Insira um filme por linha:</p>
        <textarea id="listaFilmes" placeholder="Ex:&#10;Matrix&#10;Pulp Fiction&#10;Shrek"></textarea>
        
        <button class="btn-sortear" onclick="sortear()">🎲 SORTEAR FILME</button>
        <button class="btn-limpar" onclick="limpar()">Limpar Lista</button>

        <div id="resultado">Dê o play! 🍿</div>
    </div>

    <script>
        const areaTexto = document.getElementById('listaFilmes');
        const displayResultado = document.getElementById('resultado');

        // Carregar lista salva ao abrir o app
        window.onload = () => {
            const salva = localStorage.getItem('minhaListaDeFilmes');
            if (salva) areaTexto.value = salva;
        };

        // Salvar automaticamente enquanto digita
        areaTexto.addEventListener('input', () => {
            localStorage.setItem('minhaListaDeFilmes', areaTexto.value);
        });

        function sortear() {
            const linhas = areaTexto.value.split('\n').filter(f => f.trim() !== "");
            
            if (linhas.length === 0) {
                displayResultado.innerText = "⚠️ Escreva alguns filmes primeiro!";
                return;
            }

            displayResultado.classList.remove('highlight');
            void displayResultado.offsetWidth; // Truque para reiniciar animação CSS

            const sorteado = linhas[Math.floor(Math.random() * linhas.length)];
            displayResultado.innerText = "🎬 " + sorteado;
            displayResultado.classList.add('highlight');
        }

        function limpar() {
            if (confirm("Deseja apagar toda a lista?")) {
                areaTexto.value = "";
                localStorage.removeItem('minhaListaDeFilmes');
                displayResultado.innerText = "Lista limpa!";
            }
        }
    </script>
</body>
</html>
